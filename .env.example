# Browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Required once to create/claim the admin session from the admin route.
ADMIN_SETUP_KEY=change-this-before-deploying

# Optional internal-event switches
NEXT_PUBLIC_APP_NAME=Designs Direct Live Price Game
NEXT_PUBLIC_REQUIRE_TURNSTILE=false
NEXT_PUBLIC_DEMO_MODE=true
